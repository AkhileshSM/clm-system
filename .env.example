DATA_PROVIDER=mock
MOCK_DATA_PATH=mock-data/sprint_data.json

# MOCK_DATA_PATH can be relative to the process working directory or absolute.
# Use jira_mcp only when a Jira MCP HTTP bridge is running.
# DATA_PROVIDER=jira_mcp
# JIRA_MCP_URL=http://localhost:3001/mcp
# JIRA_MCP_SPRINT_TOOL=jira_get_current_sprint
# JIRA_MCP_ENGINEER_TOOL=jira_get_engineer_workload

# Local LLM provider
LLM_PROVIDER=ollama
OLLAMA_MODEL=gemma4:31b-cloud
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_TIMEOUT_SECONDS=120

# Cloud LLM provider
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o
